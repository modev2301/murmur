{
  "manifest_version": 3,
  "name": "Murmur",
  "version": "0.1.0",
  "description": "Captures browser timing data and sends it to the local Murmur agent",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:9876/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
